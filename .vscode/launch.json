{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Trip Architect: Debug app (FastAPI + Gradio)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.main:app",
                "--host",
                "127.0.0.1",
                "--port",
                "8000"
            ],
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "justMyCode": true,
            "console": "integratedTerminal"
        },
        {
            "name": "Trip Architect: Debug current test file",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "${file}",
                "-v",
                "-s"
            ],
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "justMyCode": true,
            "console": "integratedTerminal"
        }
    ]
}
